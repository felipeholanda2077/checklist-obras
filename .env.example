# Chave de API da Eduzz — valida a assinatura dos webhooks
# Encontre em: Painel Eduzz > Perfil > Chave de API
EDUZZ_API_KEY=sua_chave_aqui

# (Opcional) URL de notificação externa para cada compra recebida
# Exemplos: Discord Webhook, Slack Webhook, n8n, Make (Integromat)
NOTIFICATION_WEBHOOK_URL=
